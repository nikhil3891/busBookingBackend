{
  "name": "bus-booking-backend",
  "version": "1.0.0",
  "description": "online bus booking app backend",
  "main": "dist/server.js",
  "scripts": {
    "prestart": "pnpm build",
    "start": "node dist/server.js",
    "dev": "nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "build": "tsc",
    "lint": "eslint . --ext .ts",
    "test": "jest --runInBand --detectOpenHandles",
    "test:unit": "jest --runInBand --testPathPatterns='__tests__' --detectOpenHandles",
    "test:e2e": "jest --runInBand --testPathPatterns='tests/e2e' --detectOpenHandles",
    "test:coverage": "jest --runInBand --coverage --detectOpenHandles",
    "test:watch": "jest --watch"
  },
  "keywords": [],
  "author": "nikhil tiwari",
  "license": "ISC",
  "packageManager": "pnpm@10.17.1",
  "dependencies": {
    "@bull-board/api": "^7.1.5",
    "@bull-board/express": "^7.1.5",
    "@bull-board/ui": "^7.1.5",
    "axios": "^1.12.2",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.77.6",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.2",
    "jwt": "^0.2.0",
    "moment": "^2.30.1",
    "mongoose": "^8.19.1",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.9",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.18.0",
    "socket.io": "^4.8.3",
    "winston": "^3.18.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^8.2.3",
    "@types/express": "^5.0.3",
    "@types/ioredis": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.7.0",
    "@types/nodemailer": "^8.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/socket.io": "^3.0.2",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "jest-mock-extended": "^4.0.1",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
